SANDBOX_NAMESPACE=pi-sandbox
SANDBOX_POOL_SIZE=8
SANDBOX_POD_PREFIX=sandbox-runner
SANDBOX_CONTAINER=runner
SANDBOX_WORKDIR=/workspace

QUEUE_MAX_WAIT_MS=15000
TOOL_TIMEOUT_MS=30000
LEASE_TTL_SECONDS=45

PORT=3000

PI_PROVIDER=anthropic
PI_MODEL=claude-sonnet-4-5
ANTHROPIC_API_KEY=your-real-api-key

PI_PROVIDER=google
PI_MODEL=gemini-2.5-flash
GEMINI_API_KEY=your-real-api-key